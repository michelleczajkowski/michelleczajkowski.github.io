<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Research Presentations | Michelle Czajkowski</title>
  <style>
    :root {
      --maxw: 980px;
      --pad: 18px;
      --border: #e6e6e6;
      --muted: #555;
      --link: #0b57d0;
    }
    body {
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.5;
      margin: 0;
      padding: 0;
      color: #111;
      background: #fff;
    }
    header, main, footer {
      max-width: var(--maxw);
      margin: 0 auto;
      padding: calc(var(--pad) * 1.25) var(--pad);
    }
    header h1 {
      margin: 0 0 6px 0;
      font-size: 1.8rem;
    }
    header p {
      margin: 0;
      color: var(--muted);
    }
    section {
      margin-top: 28px;
    }
    section h2 {
      font-size: 1.25rem;
      margin: 0 0 10px 0;
    }
    ul.list {
      list-style: none;
      padding: 0;
      margin: 0;
      border-top: 1px solid var(--border);
    }
    li.item {
      padding: 14px 0;
      border-bottom: 1px solid var(--border);
    }
    .meta {
      font-size: 0.95rem;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .meta strong {
      color: #111;
      font-weight: 650;
    }
    .title {
      font-size: 1.05rem;
      margin: 0 0 6px 0;
      font-weight: 650;
    }
    .summary {
      margin: 0 0 8px 0;
    }
    .links a {
      color: var(--link);
      text-decoration: none;
      margin-right: 12px;
      font-weight: 600;
    }
    .links a:hover {
      text-decoration: underline;
    }
    .tag {
      display: inline-block;
      font-size: 0.8rem;
      padding: 2px 8px;
      border: 1px solid var(--border);
      border-radius: 999px;
      margin-left: 8px;
      color: var(--muted);
      vertical-align: middle;
    }
    footer {
      color: var(--muted);
      font-size: 0.9rem;
      padding-top: 0;
    }
  </style>
</head>

